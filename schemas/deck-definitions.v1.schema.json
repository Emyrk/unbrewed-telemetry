{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unbrewed.xyz/schemas/telemetry/deck-definitions.v1.schema.json",
  "title": "Unbrewed Telemetry Deck Definitions v1",
  "description": "A batch of deck (hero) definitions pushed by a content producer to seed the versioned deck registry.",
  "type": "object",
  "required": ["schemaVersion", "decks"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "source": {
      "type": "string",
      "minLength": 1,
      "examples": ["engine", "manual", "backfill"]
    },
    "contentVersion": {
      "type": "string",
      "description": "Optional producer content version stamped onto every deck in this batch."
    },
    "decks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/deck" }
    }
  },
  "$defs": {
    "deck": {
      "type": "object",
      "required": ["deckId", "version", "cards"],
      "additionalProperties": false,
      "properties": {
        "deckId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "tier": { "type": "string" },
        "cards": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/card" }
        }
      }
    },
    "card": {
      "type": "object",
      "required": ["type", "quantity"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "enum": ["attack", "defense", "versatile", "scheme"] },
        "value": { "type": ["integer", "null"] },
        "boost": { "type": ["integer", "null"] },
        "quantity": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
