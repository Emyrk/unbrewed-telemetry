{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/game-submission.schema.json",
  "title": "Game Submission",
  "description": "A single completed game submitted to the balance tracker. Formats, bosses, maps, and bot names are open-ended strings so new categories can be added without schema changes.",
  "type": "object",
  "required": ["format", "map", "teams", "winner"],
  "additionalProperties": false,
  "properties": {
    "gameId": {
      "type": "string",
      "description": "Server-assigned unique id. Optional; the tracker can assign one on ingest."
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the game was submitted (ISO 8601)."
    },
    "source": {
      "type": "string",
      "description": "What produced this record.",
      "examples": ["server", "manual", "ai-lab"]
    },
    "format": {
      "type": "string",
      "minLength": 1,
      "description": "Open-ended format string. New values automatically become new categories in the dashboard.",
      "examples": ["1v1", "2v2", "2v1", "3FFA"]
    },
    "boss": {
      "type": ["string", "null"],
      "description": "Boss category for boss-battle games (e.g. the boss's name). Null/omitted for non-boss games. Convention: the boss is teams[0].",
      "examples": ["Marrow King", "Onyxia"]
    },
    "map": {
      "type": "string",
      "minLength": 1,
      "description": "Map the game was played on."
    },
    "teams": {
      "type": "array",
      "minItems": 2,
      "description": "One entry per side, in seating order. Supports any team count (FFA) and any team size.",
      "items": {
        "type": "object",
        "required": ["seats"],
        "additionalProperties": false,
        "properties": {
          "seats": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/seat" }
          }
        }
      }
    },
    "winner": {
      "type": "integer",
      "minimum": 0,
      "description": "Index into teams of the winning side."
    },
    "draw": {
      "type": "boolean",
      "default": false,
      "description": "True if the game ended in a draw; winner is ignored when true."
    },
    "endCondition": {
      "type": "string",
      "description": "How the game ended. Open-ended, but prefer the listed values.",
      "examples": ["hero_defeated", "deck_out", "concede", "timeout", "objective"]
    },
    "turns": {
      "type": "integer",
      "minimum": 1,
      "description": "Total turns played."
    },
    "durationSeconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Wall-clock game length in seconds."
    },
    "firstPlayerTeam": {
      "type": "integer",
      "minimum": 0,
      "description": "Index into teams of the side that took the first turn. Enables first-player-advantage analysis."
    },
    "telemetry": { "$ref": "#/$defs/telemetry" },
    "notes": {
      "type": ["string", "null"],
      "description": "Free-form annotation (e.g. 'playtest of nerfed list')."
    }
  },
  "$defs": {
    "seat": {
      "type": "object",
      "required": ["deck", "pilot"],
      "additionalProperties": false,
      "properties": {
        "deck": {
          "type": "string",
          "pattern": "^[^@\\s]+@[^@\\s]+$",
          "description": "Versioned deck identifier, '<deck-id>@<version>'. Versioning keeps pre- and post-balance-change games separate.",
          "examples": ["whisperfang@2.0.1", "marrow-king@1.3.0"]
        },
        "pilot": {
          "type": "string",
          "pattern": "^(human|bot:[^\\s]+)$",
          "description": "'human' or a namespaced bot id. Bot ids are open-ended (difficulty tiers or named bots).",
          "examples": ["human", "bot:easy", "bot:medium", "bot:hard", "bot:gruncle-v2"]
        },
        "playerId": {
          "type": "string",
          "description": "Pseudonymous player id, humans only. Enables skill-bracket splits without PII."
        }
      }
    },
    "seatRef": {
      "type": "array",
      "description": "Address of a seat: [teamIndex, seatIndex].",
      "prefixItems": [
        { "type": "integer", "minimum": 0 },
        { "type": "integer", "minimum": 0 }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "telemetry": {
      "type": "object",
      "description": "Optional per-game instrumentation, typically emitted by AI-vs-AI games. Feeds card-influence and deep-dive views.",
      "additionalProperties": false,
      "properties": {
        "cardsPlayed": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seat", "card"],
            "additionalProperties": false,
            "properties": {
              "seat": { "$ref": "#/$defs/seatRef" },
              "card": { "type": "string", "description": "Card id within the deck." },
              "turn": { "type": "integer", "minimum": 1 },
              "context": {
                "type": "string",
                "description": "How the card was used.",
                "examples": ["attack", "defense", "scheme", "boost", "discard"]
              }
            }
          }
        },
        "damageDealt": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seat", "total"],
            "additionalProperties": false,
            "properties": {
              "seat": { "$ref": "#/$defs/seatRef" },
              "total": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "finalHealth": {
          "type": "array",
          "description": "Remaining health per seat, shaped like teams: one inner array per team, one integer per seat (0 = defeated).",
          "items": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
