PORT=8788
DATABASE_URL=postgres://unbrewed:unbrewed@localhost:55432/unbrewed_telemetry
PUBLIC_URL=http://localhost:8788

# Discord OAuth for /admin. ADMIN_DISCORD_IDS is a comma-separated allowlist.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8788/auth/discord/callback
ADMIN_DISCORD_IDS=
SECURE_COOKIES=0

# Named bearer keys created in /admin are the primary machine authentication.
TELEMETRY_API_KEY=
# Legacy HMAC compatibility only. New producers should use TELEMETRY_API_KEY.
TELEMETRY_SECRET=dev-telemetry-secret-change-me
# Used only by direct local seed tooling, not authenticated HTTP submissions.
TELEMETRY_SOURCE=
# Set to 1 only for local manual testing without bearer or HMAC authentication.
ALLOW_UNAUTHENTICATED_INGEST=0
# Set to 1 if you want the web process to run migrations on startup.
RUN_MIGRATIONS_ON_START=0
