PORT=8788
DATABASE_URL=postgres://unbrewed:unbrewed@localhost:55432/unbrewed_telemetry
TELEMETRY_SECRET=dev-telemetry-secret-change-me
# Optional label for command-line generated/seeded submissions. Defaults to <hostname>:<user>:lab.
TELEMETRY_SOURCE=
# Set to 1 only for local manual testing without HMAC headers.
ALLOW_UNAUTHENTICATED_INGEST=0
# Set to 1 if you want the web process to run migrations on startup.
RUN_MIGRATIONS_ON_START=0
